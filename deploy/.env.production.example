# Copy to deploy/.env on the VPS and replace every placeholder.
# Do not commit deploy/.env.

COMPOSE_PROJECT_NAME=nightvex_production

TINODE_DOMAIN=vshp-project.ru
TINODE_RESET_DB=false
TINODE_UPGRADE_DB=false
TINODE_DB_NAME=tinode
TINODE_SAMPLE_DATA=
TINODE_AUTH_TOKEN_KEY=replace-with-base64-encoded-32-random-bytes
TINODE_UID_ENCRYPTION_KEY=replace-with-base64-encoded-16-random-bytes

POSTGRES_DB=postgres
POSTGRES_USER=tinode
POSTGRES_PASSWORD=replace-with-a-strong-production-password

CADDY_EMAIL=admin@example.com

FCM_PUSH_ENABLED=false
FCM_CRED_FILE=/opt/nightvex/secrets/firebase-service-account.json
WEBRTC_ENABLED=true
TURN_REALM=vshp-project.ru
TURN_SECRET=replace-with-turn-secret-outside-git
