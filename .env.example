# Safe example values only. Copy to .env for local development and replace placeholders.

COMPOSE_PROJECT_NAME=nightvex_messenger
PUBLIC_APP_NAME=NightVex Messenger
PUBLIC_WEB_ORIGIN=https://vshp-project.ru
PUBLIC_API_ORIGIN=https://vshp-project.ru
PUBLIC_WS_ORIGIN=wss://vshp-project.ru

TINODE_DOMAIN=vshp-project.ru
TINODE_RESET_DB=false
TINODE_UPGRADE_DB=false
TINODE_DB_NAME=tinode
TINODE_SAMPLE_DATA=
TINODE_AUTH_TOKEN_KEY=replace-with-base64-encoded-32-random-bytes
TINODE_UID_ENCRYPTION_KEY=replace-with-base64-encoded-16-random-bytes

POSTGRES_DB=tinode
POSTGRES_USER=tinode
POSTGRES_PASSWORD=replace-with-a-strong-local-password

CADDY_EMAIL=admin@example.com
